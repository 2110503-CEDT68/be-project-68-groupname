@startuml BooksSequenceDiagram

participant Client
participant BooksController as "Books\nController"
participant BookModel as "Book\nModel"
participant CampgroundModel as "Campground\nModel"
participant Database as "MongoDB"

== Get All Books ==
Client -> BooksController: GET /api/v1/books\n(Authorization: Bearer token)
BooksController -> BooksController: Verify user authentication
alt User is Admin
    BooksController -> BookModel: Find all books
else User is Regular User
    BooksController -> BookModel: Find books by user ID
end
BookModel -> Database: Query books collection
Database -> BookModel: Books found
BookModel -> BooksController: Books array
BooksController -> Client: 200 OK\n{count, books data}

== Get Single Book ==
Client -> BooksController: GET /api/v1/books/{id}\n(Authorization: Bearer token)
BooksController -> BooksController: Verify user authentication
BooksController -> BookModel: Find book by ID
BookModel -> Database: Query books collection
Database -> BookModel: Book found
BookModel -> BooksController: Book object
BooksController -> Client: 200 OK\n{book data}

== Add New Book ==

Client -> BooksController: POST /api/v1/books\n(startDate, endDate...)\n(Authorization)

' --- authentication ---
BooksController -> BooksController: Verify authentication
alt Invalid token
    BooksController -> Client: 401 Unauthorized
end

' --- request validation ---
BooksController -> BooksController: Validate request body
alt Invalid data
    BooksController -> Client: 400 Bad Request
end

' --- campground validation ---
BooksController -> CampgroundModel: findById(campgroundId)
CampgroundModel -> Database: Query campground
Database -> CampgroundModel: Result
CampgroundModel -> BooksController: Campground object

alt Campground not found
    BooksController -> Client: 404 Campground not found
end

' --- business rules for regular users ---
alt User is Regular User

    BooksController -> BooksController: Check booking limit
    alt Limit exceeded
        BooksController -> Client: 400 Booking limit exceeded
    end

    BooksController -> BookModel: findOverlappingBookings(user, newDates)
    BookModel -> Database: Query books collection
    Database -> BookModel: overlapped bookings
    BookModel -> BooksController: overlappedBookings[]

    alt Overlap exists
        BooksController -> Client: 400 Overlapped booking
    end
end

' --- create booking ---
BooksController -> BookModel: create(bookData)
BookModel -> Database: Insert document
Database -> BookModel: Book created
BookModel -> BooksController: Book object

BooksController -> Client: 201 Created\n{book}

== Update Book ==

Client -> BooksController: PUT /api/v1/books/{id}\n(updated data)\n(Authorization)

BooksController -> BooksController: Verify authentication

' --- find existing booking ---
BooksController -> BookModel: findById(id)
BookModel -> Database: Query books collection
Database -> BookModel: Book / null
BookModel -> BooksController: Book object

alt Book not found
    BooksController -> Client: 404 No book with id
end

' --- authorization check ---
BooksController -> BooksController: Check owner OR admin
alt Unauthorized
    BooksController -> Client: 403 Not authorized
end

' --- compute booking dates ---
BooksController -> BooksController: start = req.body.startDate || book.startDate
BooksController -> BooksController: end = req.body.endDate || book.endDate
BooksController -> BooksController: nights = ceil((end - start)/1day)

alt nights <= 0
    BooksController -> Client: 400 End date must be after start date
end

alt nights > 3 AND role != admin
    BooksController -> Client: 400 Booking cannot exceed 3 nights
end

' --- overlap check ---
BooksController -> BookModel: findOne({_id != id,\nuser, campground,\nstartDate <= end,\nendDate >= start})
BookModel -> Database: Query books collection
Database -> BookModel: Overlap / null
BookModel -> BooksController: overlap result

alt Overlap exists AND role != admin
    BooksController -> Client: 400 Updated dates overlap
end

' --- perform update ---
BooksController -> BookModel: findByIdAndUpdate(id, req.body,\n{new: true, runValidators: true})
BookModel -> Database: Update document
Database -> BookModel: Updated book
BookModel -> BooksController: Updated book object

BooksController -> Client: 200 OK\n{success: true, data: book}

== Delete Book ==
Client -> BooksController: DELETE /api/v1/books/{id}\n(Authorization: Bearer token)
BooksController -> BooksController: Verify user authentication\nVerify authorization
BooksController -> BookModel: Find book by ID
BookModel -> Database: Query books collection
Database -> BookModel: Book found
BookModel -> BooksController: Book object
BooksController -> BookModel: Delete book
BookModel -> Database: Delete document
Database -> BookModel: Deleted
BookModel -> BooksController: Success
BooksController -> Client: 200 OK\n{success: true}

@enduml
