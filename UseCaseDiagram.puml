@startuml UseCaseDiagram

skinparam actorBackgroundColor #E1F5FF
skinparam usecaseBackgroundColor #FFF9C4
skinparam packageBackgroundColor #FAFAFA
skinparam shadowing false
left to right direction

actor "Guest User" as Guest
actor "Authenticated User" as User
actor "Admin" as Admin

package "Authentication" {
    usecase "Register Account" as UC_Register
    usecase "Login" as UC_Login
    usecase "Logout" as UC_Logout
    usecase "View My Profile" as UC_GetProfile
}

package "Books Management" {
    usecase "View All Books" as UC_GetBooks
    usecase "View Book Details" as UC_GetBook
    usecase "Create Book" as UC_AddBook
    usecase "Update Own Book" as UC_UpdateOwn
    usecase "Delete Own Book" as UC_DeleteOwn
    usecase "Update Any Book" as UC_UpdateAny
    usecase "Delete Any Book" as UC_DeleteAny
}

package "Campgrounds Management" {
    usecase "View All Campgrounds" as UC_GetCampgrounds
    usecase "View Campground Details" as UC_GetCampground
    usecase "Add New Campground" as UC_AddCampground
    usecase "Update Campground" as UC_UpdateCampground
    usecase "Delete Campground" as UC_DeleteCampground
}

' ===== Guest =====
Guest --> UC_Register
Guest --> UC_Login
Guest --> UC_GetBooks
Guest --> UC_GetBook
Guest --> UC_GetCampgrounds
Guest --> UC_GetCampground

' ===== Authenticated User =====
User --> UC_Logout
User --> UC_GetProfile
User --> UC_GetBooks
User --> UC_GetBook
User --> UC_AddBook
User --> UC_UpdateOwn
User --> UC_DeleteOwn
User --> UC_GetCampgrounds
User --> UC_GetCampground

' ===== Admin =====
Admin --> UC_Logout
Admin --> UC_GetProfile
Admin --> UC_GetBooks
Admin --> UC_GetBook
Admin --> UC_AddBook
Admin --> UC_UpdateAny
Admin --> UC_DeleteAny
Admin --> UC_GetCampgrounds
Admin --> UC_GetCampground
Admin --> UC_AddCampground
Admin --> UC_UpdateCampground
Admin --> UC_DeleteCampground

@enduml